#!/usr/bin/env bash
#
# AdaptiveSound pre-commit hook.
#
# Enforces the flow documented in DEVELOPMENT.md:
#   1. Format staged Swift / C++ / Obj-C++ files (clang-format, swiftformat)
#   2. Lint staged Swift files (swiftlint)  -> errors block the commit
#   3. Static-analyse staged C++ files (clang-tidy) -> errors block the commit
#
# The required tools (clang-format, swiftformat, swiftlint, clang-tidy) are REQUIRED, not
# optional: if one is missing for a file type you staged, the hook HARD-FAILS and blocks the
# commit (it no longer skips with a warning). The only escape hatch is `git commit --no-verify`.
#
# Only STAGED files are processed. Reformatted files are re-staged so the
# commit reflects the formatted result.
#
# Install: handled by `core.hooksPath=.githooks` (see scripts note / README).
# Bypass once (not recommended): git commit --no-verify

set -uo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root" || exit 1

# ANSI helpers
red()    { printf '\033[31m%s\033[0m\n' "$*"; }
yellow() { printf '\033[33m%s\033[0m\n' "$*"; }
green()  { printf '\033[32m%s\033[0m\n' "$*"; }

# clang-tidy is keg-only under Homebrew LLVM; prefer that path, fall back to PATH.
CLANG_TIDY=""
if [[ -x /opt/homebrew/opt/llvm/bin/clang-tidy ]]; then
    CLANG_TIDY=/opt/homebrew/opt/llvm/bin/clang-tidy
elif command -v clang-tidy >/dev/null 2>&1; then
    CLANG_TIDY="$(command -v clang-tidy)"
fi

# Collect staged files (added/copied/modified), NUL-safe.
# Uses a read loop (not mapfile) for macOS bash 3.2 compatibility.
swift_files=()
cpp_files=()
while IFS= read -r -d '' f; do
    [[ -f "$f" ]] || continue
    case "$f" in
        *.swift)            swift_files+=("$f") ;;
        *.h|*.hpp|*.cpp|*.cc|*.mm) cpp_files+=("$f") ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACM -z)

fail=0

# ---------------------------------------------------------------------------
# 1. Formatting (auto-fix + re-stage)
# ---------------------------------------------------------------------------
if ((${#cpp_files[@]})); then
    if command -v clang-format >/dev/null 2>&1; then
        # stderr suppressed: .clang-format declares Language: Cpp, so clang-format
        # emits a benign "does not support Objective-C" notice on .mm files.
        clang-format -i "${cpp_files[@]}" 2>/dev/null && git add -- "${cpp_files[@]}"
    else
        red "❌ clang-format not found — REQUIRED for staged C++ files."
        red "    Install it (see docs/development/DEVELOPMENT.md), or bypass with --no-verify."
        fail=1
    fi
fi

if ((${#swift_files[@]})); then
    if command -v swiftformat >/dev/null 2>&1; then
        swiftformat "${swift_files[@]}" >/dev/null 2>&1 && git add -- "${swift_files[@]}"
    else
        red "❌ swiftformat not found — REQUIRED for staged Swift files."
        red "    Install it (see docs/development/DEVELOPMENT.md), or bypass with --no-verify."
        fail=1
    fi
fi

# ---------------------------------------------------------------------------
# 2. SwiftLint (blocking)
# ---------------------------------------------------------------------------
if ((${#swift_files[@]})); then
    if command -v swiftlint >/dev/null 2>&1; then
        # Non-zero exit => error-severity violations (e.g. force_unwrapping). Warnings don't block.
        if ! swiftlint lint --quiet "${swift_files[@]}"; then
            red "❌ SwiftLint reported error-severity violations (these block the commit)."
            fail=1
        fi
    else
        red "❌ swiftlint not found — REQUIRED for staged Swift files."
        red "    Install it (see docs/development/DEVELOPMENT.md), or bypass with --no-verify."
        fail=1
    fi
fi

# ---------------------------------------------------------------------------
# 3. clang-tidy (blocking; graceful skip if unavailable)
# ---------------------------------------------------------------------------
if ((${#cpp_files[@]})); then
    if [[ -n "$CLANG_TIDY" ]]; then
        # Parse flags come from the single source of truth shared with the strict-gate
        # and build-null-test.sh, so the hook analyses the SAME translation units the
        # compiler builds (incl. the -isystem/-D flags that make FileDecodeSource.mm's
        # __has_include(<libavformat/...>) FFmpeg branch parse). See the library header.
        source "$repo_root/scripts/lib/cxx-analysis-flags.sh"
        # Constant across files: resolve once (xcrun etc.) rather than per file.
        core_flags=($(cxx_analysis_core_flags))
        test_extra_flags=($(cxx_test_extra_flags))
        bridge_extra_flags=($(cxx_bridge_extra_flags))

        for f in "${cpp_files[@]}"; do
            # Per-file language mode (.h/.hpp analysed as Obj-C++, a C++ superset).
            # cxx_lang_flags always emits >=1 flag (bash 3.2 + set -u safe).
            lang_flags=($(cxx_lang_flags "$f"))
            # Layer extras by repo-relative staged path: test TUs get the libebur128
            # oracle include + test-data-dir macro; the test-support bridge gets its own
            # include/ dir (so #include "EQTestBridge.h" resolves, as it did before).
            file_flags=("${core_flags[@]}")
            case "$f" in
                Tests/*)                      file_flags+=("${test_extra_flags[@]}") ;;
                Sources/AudioDSPTestBridge/*) file_flags+=("${bridge_extra_flags[@]}") ;;
            esac
            # --quiet hides the "N warnings generated" summary. Capture output and
            # only surface it when the file actually fails (WarningsAsErrors), so
            # non-blocking style warnings don't spam every commit.
            ct_out="$("$CLANG_TIDY" "$f" --quiet --use-color=false -- "${lang_flags[@]}" "${file_flags[@]}" 2>&1)"
            if [[ $? -ne 0 ]]; then
                red "❌ clang-tidy reported issues in $f"
                printf '%s\n' "$ct_out"
                fail=1
            fi
        done
    else
        red "❌ clang-tidy not found — REQUIRED for staged C++ files."
        red "    Install with: brew install llvm  (see docs/development/DEVELOPMENT.md), or bypass with --no-verify."
        fail=1
    fi
fi

if ((fail)); then
    red "Commit aborted by pre-commit hook. Fix the issues above, or re-run with --no-verify to bypass."
    exit 1
fi

green "✅ pre-commit checks passed."
exit 0
