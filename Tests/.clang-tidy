# clang-tidy config for the Tests/ tree.
#
# Inherits the strict repo-root config (which gates the AudioDSP production tree),
# then relaxes a handful of checks that are inappropriate for test/harness code.
# The production gate is unaffected — this applies only under Tests/.
InheritParentConfig: true
Checks: >
  -bugprone-suspicious-memory-comparison,
  -cert-exp42-c,
  -cert-flp37-c,
  -cert-err33-c,
  -bugprone-random-generator-seed,
  -cert-msc32-c,
  -cert-msc51-cpp,
  -cppcoreguidelines-avoid-non-const-global-variables,
  -cppcoreguidelines-avoid-magic-numbers,
  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-redundant-member-init,
  -readability-math-missing-parentheses,
  -readability-use-std-min-max,
  -cppcoreguidelines-pro-type-vararg,
  -hicpp-vararg,
  -cppcoreguidelines-avoid-c-arrays,
  -modernize-avoid-c-arrays,
  -hicpp-avoid-c-arrays,
  -bugprone-unchecked-string-to-number-conversion,
  -cert-err34-c,
  -cert-dcl59-cpp,
  -modernize-use-std-numbers
#
# Rationale (all standard, intentional null-test patterns):
#   - memcmp on float arrays  -> bit-exact null-test comparison is the whole point
#   - fixed RNG seeds         -> reproducible test signals. This covers BOTH
#                                bugprone-random-generator-seed AND cert-msc32-c/cert-msc51-cpp
#                                (seeding a PRNG with a compile-time constant): deterministic
#                                seeding is the INTENT in tests, never a security concern — so
#                                the whole test tree opts out here rather than per-line NOLINTs.
#   - non-const global        -> the test result accumulator
#   - magic numbers / short names / parens / std::max / redundant init
#                             -> ordinary test-fixture ergonomics
#   - cert-dcl59-cpp          -> TestSupport.h is a header-only test harness; its unnamed
#                                namespaces give each test binary its own isolated copy of
#                                the harness (internal linkage), not shipped code.
#   - modernize-use-std-numbers -> golden/reference vectors hard-code literal constants
#                                (a sqrt2 that differs from std::numbers::sqrt2_v by ~2.4e-08);
#                                rewriting them would CHANGE the expected test value.
